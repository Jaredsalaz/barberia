# DeepSeek API Configuration
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# NVIDIA API Configuration
NVIDIA_API_KEY=your_nvidia_api_key_here

# Database Configuration (PostgreSQL)
POSTGRES_USER=your_postgres_user_here
POSTGRES_PASSWORD=your_postgres_password_here
POSTGRES_DB=your_postgres_db_name_here
DATABASE_URL=postgresql://your_postgres_user_here:your_postgres_password_here@localhost:5432/your_postgres_db_name_here

# Redis Configuration
REDIS_URL=redis://localhost:6379/0

# WhatsApp & OpenWA Configuration
WHATSAPP_WEBHOOK_URL=http://host.docker.internal:8001/api/v1/webhook/whatsapp
OPENWA_API_KEY=your_openwa_api_key_here

# PayPal Configuration
PAYPAL_CLIENT_ID=your_paypal_client_id_here
PAYPAL_CLIENT_SECRET=your_paypal_client_secret_here
PAYPAL_MODE=sandbox

# Email Configuration (GMAIL SMTP)
GMAIL_USER=your_gmail_email_here@gmail.com
GMAIL_PASSWORD=your_gmail_app_password_here
